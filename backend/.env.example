# InkSight Backend Environment Variables

# ============================================
# LLM API Keys (Multiple Providers)
# ============================================
# 开发者需要自行申请并填写以下 API Key
# 用户在配置页面选择模型时，系统会自动使用对应的 Key

# Deepseek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里百炼 (https://bailian.console.aliyun.com)
DASHSCOPE_API_KEY=sk-your-aliyun-api-key-here

# 月之暗面 (https://platform.moonshot.cn)
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here

# 火山方舟 (https://console.volcengine.com/ark)
# API Key 管理: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 模型列表: https://www.volcengine.com/docs/82379/1330310?lang=zh
ARK_API_KEY=sk-your-ark-api-key-here

# 火山方舟接入点 Endpoint ID（推荐使用）
# 使用接入点可以获得限流、计费类型、运行状态查询、监控、安全等高级能力
# 创建接入点: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
# 若配置了 ARK_ENDPOINT_ID，则调用时使用接入点；否则使用模型 ID 调用
ARK_ENDPOINT_ID=

# ============================================
# Voice / Realtime Chat
# ============================================

# 当前语音链路仅保留百炼 WebSocket 实时方案:
# - STT: qwen3-asr-flash-realtime (实时 ASR WebSocket)
# - TTS: cosyvoice-v3-plus (流式 TTS WebSocket)
# - LLM: 复用用户或系统的现有 LLM 配置

# 百炼 API 密钥（STT/TTS 共用，留空则回退到 DASHSCOPE_API_KEY）
VOICE_DASHSCOPE_API_KEY=

# 可选：分别为 STT / TTS 单独配置密钥
VOICE_STT_API_KEY=
VOICE_TTS_API_KEY=

# Realtime STT (DashScope WebSocket)
VOICE_REALTIME_ASR_MODEL=qwen3-asr-flash-realtime
VOICE_REALTIME_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
VOICE_REALTIME_ASR_LANGUAGE=zh
VOICE_REALTIME_ASR_IDLE_TIMEOUT_SECONDS=20
VOICE_REALTIME_ASR_MAX_EVENT_BYTES=15728640

# Streaming TTS (DashScope WebSocket)
VOICE_STREAMING_TTS_ENABLED=1
VOICE_STREAMING_TTS_MODEL=cosyvoice-v3-plus
VOICE_STREAMING_TTS_VOICE=longanyang
VOICE_STREAMING_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
VOICE_STREAMING_TTS_SAMPLE_RATE=16000
VOICE_STREAMING_TTS_VOLUME=50
VOICE_STREAMING_TTS_PITCH=1.0
VOICE_STREAMING_TTS_SPEED=1.0
VOICE_STREAMING_TTS_MAX_EVENT_BYTES=4194304
# 流式分段与预热控制
VOICE_LLM_STREAMING=1
VOICE_TTS_STREAMING=1
VOICE_TTS_STREAM_MIN_CHARS=12
VOICE_TTS_STREAM_MAX_CHARS=36
VOICE_TTS_DELTA_MIN_CHARS=6
VOICE_TTS_DELTA_MAX_CHARS=16
VOICE_TTS_DELTA_IDLE_MS=320
VOICE_WS_PARTIAL_WARMUP_MIN_CHARS=2
VOICE_WS_PARTIAL_WARMUP_STABLE_MS=180
VOICE_WS_AUDIO_CHUNK_BYTES=2048
VOICE_SERVER_VAD_ENABLED=1
VOICE_SERVER_VAD_SILENCE_MS=800

# 语音会话缓存保留时长（秒）
VOICE_TURN_TTL_SECONDS=900

# ============================================
# Application Settings
# ============================================

# Debug mode (set to 1 to enable verbose logging)
DEBUG_MODE=0

# Default city for weather (if device config not set)
DEFAULT_CITY=北京

# Database path (relative to backend directory)
DB_PATH=inksight.db

# 用户上传图片（MY_ADAPTIVE 等）磁盘缓存目录：backend/runtime_uploads/
# 按「最后访问时间」清理：每次成功 GET /api/uploads/{id} 会更新 mtime，长期仍被设备引用的图不会误删。
# 设为 0 表示不按时间删除。
INKSIGHT_UPLOADS_MAX_AGE_DAYS=30
# 所有 .bin 合计上限（MB），超出则删最久未访问的文件；设为 0 表示不限制总容量。
INKSIGHT_UPLOADS_MAX_TOTAL_MB=512

# 字体渲染引擎：bitmap（优先 fonts/bitmap）或 freetype（强制矢量）
INKSIGHT_FONT_ENGINE=bitmap
# load_font 请求的像素上限（超过则不走 bitmap 目录）。5.83″ 组件树正文字号常为 int(JSON字号×组件scale)，见下。
INKSIGHT_BITMAP_MAX_REQUEST_SIZE=28
# 请求字号与文件名中点阵档位(如 -24)的最大差；默认 3。只有 *-24.ttf 时，若请求约 20px 会全部不匹配→发糊；可把本项调到 5，或把 JSON 字号设计成「目标像素/组件scale」。
INKSIGHT_BITMAP_MAX_SIZE_DELTA=3
# 648×480 组件树 scale 上限（默认 min(648/400, 本值)）。排版间距与字号都乘同一 scale；要让正文命中 *-24 点阵：int(正文JSON字号×scale)≈24，例如在 scale=1.35 时用正文字号 18。
INKSIGHT_648_COMPONENT_SCALE_MAX=1.35

# ============================================
# 天气备用源：和风天气 QWeather（Open-Meteo 不可用时自动切换）
# ============================================
# 申请地址 https://dev.qweather.com/
# 方式一：API KEY（简单，2027年起有每日限额）
QWEATHER_API_KEY=
# 方式二：JWT（推荐，需生成 Ed25519 密钥对并上传公钥到控制台）
# QWEATHER_PRIVATE_KEY 填私钥 PEM 内容（含 BEGIN/END 行），换行用 \n 连接成一行
QWEATHER_PRIVATE_KEY=
QWEATHER_CREDENTIAL_ID=
QWEATHER_PROJECT_ID=
# API Host：控制台项目设置中获取
QWEATHER_API_HOST=devapi.qweather.com

# 天行数据 API（黄历等内容源）
# 申请地址 https://www.tianapi.com/
TIANAPI_KEY=

# Aliyun Machine Translation（阿里云机器翻译，用于多语言支持）
# 申请地址 https://mt.console.aliyun.com/
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_MT_ENDPOINT=mt.cn-hangzhou.aliyuncs.com

# ============================================
# 邮件 SMTP（密码重置验证码、绑定邮箱验证）
# ============================================
# 不配置时验证码仅打印到服务器日志（开发模式）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=1

# ============================================
# 鉴权配置
# ============================================

# 允许设备通过局域网IP访问后端（开发环境设为 *，正式环境请删除此项或填写具体域名）
# INKSIGHT_ALLOWED_HOSTS=*

# 允许局域网/本地 Origin 的跨域请求（仅开发环境启用，正式环境请删除此项）
# INKSIGHT_CORS_ALLOW_LAN=1

# 管理端点的访问密钥（配置管理、模式管理、统计概览等）
# 留空或不设置则跳过管理员鉴权（适用于本地开发）
ADMIN_TOKEN=